                        "public static void main(String[] args) {",
                        "        System.out.println(\"=== Constructor Overload ===\");",
                        "        Calculator calc1 = new Calculator();",
                        "        Calculator calc2 = new Calculator(100);",
                        "        Calculator calc3 = new Calculator(200, \"Custom\");",
                        "        System.out.println(\"calc1: \" + calc1.getResult() + \", \" + calc1.getName());",
                        "        System.out.println(\"calc2: \" + calc2.getResult() + \", \" + calc2.getName());",
                        "        System.out.println(\"calc3: \" + calc3.getResult() + \", \" + calc3.getName());",
                        "",
                        "        System.out.println(\"\\n=== Method Overload ===\");",
                        "        Calculator calc = new Calculator();",
                        "        System.out.println(\"add(int, int): \" + calc.add(10, 20));",
                        "        System.out.println(\"add(double, double): \" + calc.add(10.5, 20.5));",
                        "        System.out.println(\"add(int, int, int): \" + calc.add(1, 2, 3));",
                        "        System.out.println(\"add(String, String): \" + calc.add(\"Hello\", \"World\"));",
                        "",
                        "        System.out.println(\"\\n=== Inheritance ===\");",
                        "        Dog dog = new Dog(\"Buddy\", 3, \"Golden Retriever\");",
                        "        System.out.println(\"Dog: \" + dog.getName() + \", \" + dog.getAge() + \", \" + dog.getBreed());",
                        "        System.out.println(\"Dog speaks: \" + dog.speak());",
                        "        System.out.println(\"Dog fetches: \" + dog.fetch());",
                        "",
                        "        Bird bird = new Bird(\"Tweety\", 2, 30);",
                        "        System.out.println(\"Bird: \" + bird.getName() + \", \" + bird.getAge() + \", wingspan \" + bird.getWingSpan());",
                        "        System.out.println(\"Bird speaks: \" + bird.speak());",
                        "        System.out.println(\"Bird flies: \" + bird.fly());",
                        "",
                        "        System.out.println(\"\\n=== Abstract Class ===\");",
                        "        Rectangle rect = new Rectangle(\"Blue\", 5.0, 3.0);",
                        "        System.out.println(\"Rectangle color: \" + rect.getColor());",
                        "        System.out.println(\"Rectangle area: \" + rect.getArea());",
                        "        System.out.println(\"Rectangle perimeter: \" + rect.getPerimeter());",
                        "        System.out.println(\"Rectangle describe: \" + rect.describe());",
                        "",
                        "        System.out.println(\"\\n=== Static Members ===\");",
                        "        Counter c1 = new Counter(\"Counter1\");",
                        "        Counter c2 = new Counter(\"Counter2\", 10);",
                        "        c1.increment();",
                        "        c1.increment(5);",
                        "        c2.increment();",
                        "        System.out.println(\"Instance count: \" + Counter.getInstanceCount());",
                        "        System.out.println(\"Total count: \" + Counter.getTotalCount());",
                        "",
                        "        System.out.println(\"\\n=== Varargs ===\");",
                        "        System.out.println(\"join: \" + StringUtils.join(\", \", \"a\", \"b\", \"c\"));",
                        "        System.out.println(\"sum: \" + StringUtils.sum(1, 2, 3, 4, 5));",
                        "",
                        "        System.out.println(\"\\n=== Type Casting ===\");",
                        "        BaseClass base = new DerivedClass(\"Test\", 42);",
                        "        System.out.println(\"Upcast: \" + base.getName());",
                        "        DerivedClass derived = (DerivedClass) base;",
                        "        System.out.println(\"Downcast value: \" + derived.getValue());",
                        "",
                        "        System.out.println(\"\\n=== Inner Classes ===\");",
                        "        OuterClass outer = new OuterClass(\"OuterName\");",
                        "        OuterClass.StaticInnerClass staticInner = new OuterClass.StaticInnerClass(100);",
                        "        System.out.println(\"Static inner value: \" + staticInner.getStaticValue());",
                        "        System.out.println(\"Static inner outer name: \" + staticInner.getOuterStaticName());",
                        "",
                        "        OuterClass.MemberInnerClass memberInner = outer.new MemberInnerClass(200);",
                        "        System.out.println(\"Member inner value: \" + memberInner.getMemberValue());",
                        "        System.out.println(\"Member inner outer name: \" + memberInner.getOuterName());",
                        "",
                        "        System.out.println(\"\\n=== All tests passed! ===\");",
                        "    }"
                    ],
