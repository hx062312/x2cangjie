                        "public static String checkType(Object obj) {",
                        "        if (obj instanceof String) {",
                        "            return \"String: \" + ((String) obj).length();",
                        "        } else if (obj instanceof Integer) {",
                        "            return \"Integer: \" + ((Integer) obj).intValue();",
                        "        } else if (obj instanceof BaseClass) {",
                        "            return \"BaseClass: \" + ((BaseClass) obj).getName();",
                        "        } else if (obj instanceof DerivedClass) {",
                        "            return \"DerivedClass: \" + ((DerivedClass) obj).getValue();",
                        "        } else {",
                        "            return \"Unknown type\";",
                        "        }",
                        "    }"
