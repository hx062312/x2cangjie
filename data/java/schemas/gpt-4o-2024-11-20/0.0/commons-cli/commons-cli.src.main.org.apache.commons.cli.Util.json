                "53-65:stripLeadingHyphens": {
                    "start": 53,
                    "end": 65,
                    "body": [
                        "static String stripLeadingHyphens(final String str) {",
                        "        if (str == null) {",
                        "            return null;",
                        "        }",
                        "        if (str.startsWith(\"--\")) {",
                        "            return str.substring(2);",
                        "        }",
                        "        if (str.startsWith(\"-\")) {",
                        "            return str.substring(1);",
                        "        }",
                        "",
                        "        return str;",
                        "    }"
                    ],
