                "72-104:getOptions": {
                    "start": 72,
                    "end": 104,
                    "body": [
                        "private Options getOptions() {",
                        "        final Options options = new Options();",
                        "        //@formatter:off",
                        "        final Option help = Option.builder(\"h\")",
                        "                .longOpt(\"help\")",
                        "                .desc(\"Prints this help message\")",
                        "                .build();",
                        "        //@formatter:on",
                        "        options.addOption(help);",
                        "",
                        "        buildOptionsGroup(options);",
                        "",
                        "        //@formatter:off",
                        "        final Option t = Option.builder(\"t\")",
                        "                .required()",
                        "                .hasArg()",
                        "                .argName(\"file\")",
                        "                .build();",
                        "        final Option w = Option.builder(\"w\")",
                        "                .required()",
                        "                .hasArg()",
                        "                .argName(\"word\")",
                        "                .build();",
                        "        final Option o = Option.builder(\"o\")",
                        "                .hasArg()",
                        "                .argName(\"directory\")",
                        "                .build();",
                        "        //@formatter:on",
                        "        options.addOption(t);",
                        "        options.addOption(w);",
                        "        options.addOption(o);",
                        "        return options;",
                        "    }"
                    ],
