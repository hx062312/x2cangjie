                    "body": [
                        "static int digit16(final byte b) throws DecoderException {",
                        "        final int i = Character.digit((char) b, RADIX);",
                        "        if (i == -1) {",
                        "            throw new DecoderException(\"Invalid URL encoding: not a valid digit (radix \" + RADIX + \"): \" + b);",
                        "        }",
                        "        return i;",
                        "    }"
