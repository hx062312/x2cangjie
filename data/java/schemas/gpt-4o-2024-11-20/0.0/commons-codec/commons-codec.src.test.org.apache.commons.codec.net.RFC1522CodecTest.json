                        "        assertExpectedDecoderException(\"=?stuff?=\");",
                        "        assertExpectedDecoderException(\"=?UTF-8??=\");",
                        "        assertExpectedDecoderException(\"=?UTF-8?stuff?=\");",
                        "        assertExpectedDecoderException(\"=?UTF-8?T?stuff\");",
                        "        assertExpectedDecoderException(\"=??T?stuff?=\");",
