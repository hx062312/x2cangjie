                    "end": 85,
                    "body": [
                        "public void uninstall() throws IOException {",
                        "        // If the system output stream has been closed, out should be null, so avoid a NPE",
                        "        AnsiOutputStream out = getOut();",
                        "        if (out != null) {",
                        "            out.uninstall();",
                        "        }",
                        "    }"
